PORT=3000
MONGODB_URI=mongodb://localhost:27017/synapse

# Auth0 (see docs/AUTH0_SETUP.md)
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.synapse-framework.com
# Required for POST /auth/login (Resource Owner Password grant)
AUTH0_CLIENT_ID=your-app-client-id
AUTH0_CLIENT_SECRET=your-app-client-secret